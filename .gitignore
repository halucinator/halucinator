# run_backend_matrix.sh per-cell logs and run summary
.matrix_logs/
matrix_run.log

# `build_qemu.sh --upstream-qemu <ref>` clones vanilla upstream QEMU
# into deps/qemu-upstream-<ref>/ and applies tools/avatar-qemu-overlay
# before building into deps/build-qemu-upstream-<ref>/. Both the
# working clone and the build tree are ephemeral and per-ref so
# parallel builds for different upstream tags don't collide.
deps/qemu-upstream*/
deps/build-qemu-upstream*/
deps/build-qemu-libafl/

# Per-arch local QEMU builds (mounted into the matrix harness Docker
# container; not shipped). One directory per `-target-list` softmmu.
.build-arm/
.build-aarch64/
.build-mips/
.build-ppc/
.build-ppc64/

# Local CI replay scratch (`ci-replay.sh` plus its captured logs).
ci-replay.sh
ci-pytest.log
ci-replay.log
config-temp/
config.log
run_renode.sh
